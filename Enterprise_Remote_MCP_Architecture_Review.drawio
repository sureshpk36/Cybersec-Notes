<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Architecture Review">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="bar" value="BARCLAYS TRUSTED NETWORK" style="swimlane;rounded=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="980" height="650" as="geometry"/>
        </mxCell>

        <mxCell id="internet" value="INTERNET TRUST BOUNDARY" style="text;html=1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1010" y="330" width="180" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="fig" value="FIGMA CLOUD" style="swimlane;rounded=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="20" width="320" height="650" as="geometry"/>
        </mxCell>

        <!-- Barclays -->
        <mxCell id="dev" value="Developer&#xa;Claude Code / VS Code" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="bar"><mxGeometry x="40" y="270" width="150" height="70" as="geometry"/></mxCell>
        <mxCell id="entra" value="Microsoft Entra ID" style="rounded=1;" vertex="1" parent="bar"><mxGeometry x="240" y="60" width="170" height="70" as="geometry"/></mxCell>

        <mxCell id="opa" value="OPA Policy Engine" style="rounded=1;" vertex="1" parent="bar"><mxGeometry x="700" y="90" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="vault" value="Secrets Manager" style="rounded=1;" vertex="1" parent="bar"><mxGeometry x="700" y="180" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="audit" value="Audit Logs / SIEM" style="rounded=1;" vertex="1" parent="bar"><mxGeometry x="700" y="420" width="180" height="60" as="geometry"/></mxCell>

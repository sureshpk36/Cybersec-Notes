        <mxCell id="auth" value="Figma Authorization" style="rounded=1;" vertex="1" parent="fig"><mxGeometry x="70" y="360" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="api" value="Figma APIs" style="rounded=1;" vertex="1" parent="fig"><mxGeometry x="70" y="460" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="ws" value="Workspace / Assets" style="rounded=1;" vertex="1" parent="fig"><mxGeometry x="70" y="560" width="180" height="60" as="geometry"/></mxCell>

        <!-- edges -->
